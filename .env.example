# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (Supabase connection string)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres
DATABASE_SSL=true

# Redis (Upstash - TCP)
REDIS_URL=rediss://default:<password>@<your-upstash-host>.upstash.io:6379

# Local Redis fallback (used only when REDIS_URL is empty)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Session
SESSION_TTL_SECONDS=86400

# CORS
CORS_ORIGIN=http://localhost:3001